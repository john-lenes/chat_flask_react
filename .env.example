# Flask backend environment variables
# Copy this file to .env and fill in the values

# REQUIRED: Secret key for Flask session signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-secure-random-value

# Comma-separated list of allowed CORS origins (frontend URLs).
# Example for production: https://my-chat-app.onrender.com
CORS_ORIGINS=http://localhost:3000

# Set to "true" only in local development — never in production.
FLASK_DEBUG=false

# Port the Flask server listens on.
PORT=5000

# React frontend environment variables (react_frontend/.env)
# REACT_APP_BACKEND_URL=http://localhost:5000
